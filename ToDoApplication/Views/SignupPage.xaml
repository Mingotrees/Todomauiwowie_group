<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ToDoApplication.Views.SignupPage"
             Title="Sign Up">

    <VerticalStackLayout Padding="30" Spacing="20" VerticalOptions="Center">

        <Label Text="Create Account" FontSize="32" FontAttributes="Bold" HorizontalOptions="Center"/>

        <Entry x:Name="UsernameEntry" Placeholder="Username"/>
        <Entry x:Name="EmailEntry" Placeholder="Email" Keyboard="Email"/>
        <Entry x:Name="PasswordEntry" Placeholder="Password" IsPassword="True"/>
        <Entry x:Name="ConfirmPasswordEntry" Placeholder="Confirm Password" IsPassword="True"/>

        <Button Text="Sign Up" Clicked="OnSignupClicked" BackgroundColor="#6200EE" TextColor="White"/>

        <HorizontalStackLayout HorizontalOptions="Center" Spacing="5">
            <Label Text="Already have an account?" VerticalOptions="Center"/>
            <Button Text="Login" Clicked="OnLoginClicked" BackgroundColor="Transparent" TextColor="#6200EE"/>
        </HorizontalStackLayout>

    </VerticalStackLayout>
</ContentPage>