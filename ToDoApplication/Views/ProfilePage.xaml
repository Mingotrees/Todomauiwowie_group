<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ToDoApplication.Views.ProfilePage"
             Title="Profile">

    <VerticalStackLayout Padding="30" Spacing="20">

        <Label Text="Profile" FontSize="28" FontAttributes="Bold"/>

        <Frame CornerRadius="60" HeightRequest="120" WidthRequest="120"
               HorizontalOptions="Center" BackgroundColor="#6200EE" Padding="0">
            <Label Text="👤" FontSize="60" HorizontalOptions="Center" VerticalOptions="Center"/>
        </Frame>

        <Label x:Name="UsernameLabel" FontSize="24" FontAttributes="Bold" HorizontalOptions="Center"/>
        <Label x:Name="EmailLabel" FontSize="16" TextColor="Gray" HorizontalOptions="Center"/>

        <BoxView HeightRequest="1" BackgroundColor="#E0E0E0"/>

        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto" HorizontalOptions="Center" ColumnSpacing="40">
            <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center">
                <Label x:Name="TotalTasksLabel" FontSize="28" FontAttributes="Bold" HorizontalOptions="Center"/>
                <Label Text="Total Tasks" TextColor="Gray" HorizontalOptions="Center"/>
            </VerticalStackLayout>
            <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center">
                <Label x:Name="CompletedTasksLabel" FontSize="28" FontAttributes="Bold" HorizontalOptions="Center"/>
                <Label Text="Completed" TextColor="Gray" HorizontalOptions="Center"/>
            </VerticalStackLayout>
        </Grid>

        <BoxView HeightRequest="1" BackgroundColor="#E0E0E0"/>

        <Button Text="Logout" Clicked="OnLogoutClicked" BackgroundColor="#FF5252" TextColor="White"/>

    </VerticalStackLayout>
</ContentPage>