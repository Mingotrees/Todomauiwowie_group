<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ToDoApplication.Views.CompletedPage"
             Title="Completed">

    <Grid RowDefinitions="Auto,*" Padding="16">

        <Label Grid.Row="0" Text="Completed Tasks" FontSize="28" FontAttributes="Bold" Margin="0,10"/>

        <CollectionView Grid.Row="1" x:Name="CompletedCollection">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="0,5" Padding="15" CornerRadius="10" BorderColor="#E0E0E0">
                        <Grid ColumnDefinitions="Auto,*">
                            <Label Grid.Column="0" Text="✅" FontSize="20" VerticalOptions="Center"/>
                            <VerticalStackLayout Grid.Column="1" Margin="10,0">
                                <Label Text="{Binding Title}" FontSize="16" FontAttributes="Bold"
                                       TextDecorations="Strikethrough"/>
                                <Label Text="{Binding Description}" FontSize="13" TextColor="Gray"/>
                                <Label Text="{Binding DueDate, StringFormat='Completed by: {0:MMM dd, yyyy}'}"
                                       FontSize="12" TextColor="Green"/>
                            </VerticalStackLayout>
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView></Grid>
</ContentPage>